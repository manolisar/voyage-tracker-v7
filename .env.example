# Voyage Tracker v7 — environment configuration
#
# Copy to `.env` (gitignored) and fill in the values for your data repo.
# Vite inlines variables prefixed with VITE_ at build time.

# GitHub data repo, formatted "<owner>/<repo>".
# When empty, the app runs against the local-file adapter (reads from
# /public/data/) and all writes are no-ops — handy for offline dev.
VITE_DATA_REPO=

# Branch to read/write. Defaults to "main" when omitted.
VITE_DATA_BRANCH=main
